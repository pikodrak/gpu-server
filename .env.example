# GPU Server Configuration
# Copy to .env and fill in your values

# --- Server ---
GPU_SERVER_HOST=0.0.0.0
GPU_SERVER_PORT=8000
GPU_SERVER_DEBUG=false

# Comma-separated list of allowed CORS origins
# GPU_SERVER_ALLOWED_ORIGINS=["http://localhost:3000","http://192.168.1.100"]

# --- Authentication ---
# Comma-separated list of valid API keys (required)
GPU_SERVER_API_KEYS=["change-me-secret-key-1","change-me-secret-key-2"]

# --- GPU ---
# Device: cuda, cpu, mps (Apple Silicon)
GPU_SERVER_DEVICE=cuda

# --- LLM Inference ---
# When running in Docker, the models volume is mounted at /app/models
# GPU_SERVER_LLM_MODEL_PATH=/app/models/llama-3-8b-instruct.Q4_K_M.gguf
#
# When running without Docker, use a local path:
# GPU_SERVER_LLM_MODEL_PATH=./models/llama-3-8b-instruct.Q4_K_M.gguf
GPU_SERVER_LLM_MODEL_PATH=

# --- Stable Diffusion (Image Generation) ---
# Set to true to enable - requires diffusers to be installed
GPU_SERVER_SD_ENABLE=false
# HuggingFace model ID or local path
GPU_SERVER_SD_MODEL_ID=runwayml/stable-diffusion-v1-5

# --- Output ---
GPU_SERVER_OUTPUT_DIR=./outputs
