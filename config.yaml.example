# GPU Server - config.yaml (alternative to .env)
# Rename to config.yaml to use. .env values take precedence.

host: "0.0.0.0"
port: 8000
debug: false

# API keys (at least one required)
api_keys:
  - "change-me-secret-key-1"
  - "change-me-secret-key-2"

# Device: cuda, cpu, mps
device: cuda

# LLM model - path to a GGUF file
llm_model_path: ""
# Example: llm_model_path: "/models/llama-3-8b-instruct.Q4_K_M.gguf"

# Stable Diffusion
sd_enable: false
sd_model_id: "runwayml/stable-diffusion-v1-5"

# Output directory for saved images
output_dir: "./outputs"
