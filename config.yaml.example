# GPU Server - config.yaml (alternative to .env)
# Rename to config.yaml to use. .env / env var values take precedence over config.yaml.

host: "0.0.0.0"
port: 8000
debug: false

# API keys (at least one required)
api_keys:
  - "change-me-secret-key-1"
  - "change-me-secret-key-2"

# Device: cuda, cpu, mps
device: cuda

# ── Multi-model configuration (recommended) ──────────────────────────────────
# Define one or more models. The `name` field is what clients pass as the
# `model` parameter in API calls (e.g. model: "llama3-8b").
# `path` is an absolute path to a GGUF file on disk.
# `auto_download_url` downloads the file on first startup if `path` is empty.
# All configured models are loaded into VRAM at startup — make sure they fit.
#
# models:
#   - name: tinyllama
#     auto_download_url: "https://huggingface.co/TheBloke/TinyLlama-1.1B-Chat-v1.0-GGUF/resolve/main/tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf"
#   - name: llama3-8b
#     path: "/app/models/Meta-Llama-3-8B-Instruct.Q4_K_M.gguf"
#   - name: mistral-7b
#     path: "/app/models/mistral-7b-instruct-v0.2.Q4_K_M.gguf"

# ── Legacy single-model configuration ────────────────────────────────────────
# Kept for backward compatibility. Ignored when `models` list above is set.
# Path to a GGUF file (takes priority over auto-download):
llm_model_path: ""
# Example: llm_model_path: "/app/models/llama-3-8b-instruct.Q4_K_M.gguf"

# Auto-download a GGUF model from this URL when llm_model_path is empty.
# The Dockerfile sets this to TinyLlama 1.1B by default; override here to use a larger model.
# llm_auto_download_url: "https://huggingface.co/TheBloke/Llama-2-7B-Chat-GGUF/resolve/main/llama-2-7b-chat.Q4_K_M.gguf"

# Stable Diffusion
sd_enable: false
sd_model_id: "runwayml/stable-diffusion-v1-5"

# Output directory for saved images
output_dir: "./outputs"
